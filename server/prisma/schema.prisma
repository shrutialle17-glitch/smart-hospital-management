// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  ADMIN
  DOCTOR
  RECEPTIONIST
  PATIENT
  LAB_STAFF
  PHARMACIST
}

enum AppointmentStatus {
  PENDING
  CONFIRMED
  COMPLETED
  CANCELLED
  NO_SHOW
}

enum BloodGroup {
  A_POS
  A_NEG
  B_POS
  B_NEG
  AB_POS
  AB_NEG
  O_POS
  O_NEG
}

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  passwordHash String
  role         Role
  firstName    String
  lastName     String
  phone        String?
  profileImage String?
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  adminProfile        Admin?
  doctorProfile       Doctor?
  receptionistProfile Receptionist?
  patientProfile      Patient?
  labStaffProfile     LabStaff?
  pharmacistProfile   Pharmacist?

  notifications  Notification[]
  auditLogs      AuditLog[]
  aiInteractions AIInteraction[]

  organDonorsRegistered     OrganDonor[]     @relation("RegisteredOrganDonors")
  organRecipientsRegistered OrganRecipient[] @relation("RegisteredOrganRecipients")
  organMatchesApproved      OrganMatch[]     @relation("MatchApprover")
}

model Admin {
  id     String @id @default(uuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Doctor {
  id              String     @id @default(uuid())
  userId          String     @unique
  user            User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  departmentId    String
  department      Department @relation(fields: [departmentId], references: [id])
  specialization  String
  qualifications  String
  experience      Int // Years of experience
  consultationFee Float

  appointments          Appointment[]
  prescriptions         Prescription[]
  voiceNotes            VoiceNote[]
  prescriptionTemplates PrescriptionTemplate[]
  queueTokens           QueueToken[]
}

model Receptionist {
  id     String @id @default(uuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Patient {
  id                String      @id @default(uuid())
  userId            String      @unique
  user              User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  dob               DateTime
  gender            String
  bloodGroup        BloodGroup?
  address           String?
  emergencyContact  String?
  allergies         String?
  chronicConditions String?

  appointments      Appointment[]
  medicalRecords    MedicalRecord[]
  prescriptions     Prescription[]
  labReports        LabReport[]
  bills             Bill[]
  currentBed        Bed[]              @relation("CurrentBed")
  bedAssignments    BedAssignment[]    @relation("BedAssignments")
  ambulanceRequests AmbulanceRequest[] @relation("AmbulanceRequests")
  bloodRequests     BloodRequest[]     @relation("BloodRequests")
  queueTokens       QueueToken[]       @relation("QueueTokens")
  organDonors       OrganDonor[]       @relation("OrganDonors")
  organRecipients   OrganRecipient[]   @relation("OrganRecipients")
}

model LabStaff {
  id     String @id @default(uuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Pharmacist {
  id     String @id @default(uuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Department {
  id          String   @id @default(uuid())
  name        String   @unique
  description String?
  headName    String?
  doctors     Doctor[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Appointment {
  id         String            @id @default(uuid())
  patientId  String
  patient    Patient           @relation(fields: [patientId], references: [id])
  doctorId   String
  doctor     Doctor            @relation(fields: [doctorId], references: [id])
  date       DateTime
  startTime  DateTime
  endTime    DateTime
  status     AppointmentStatus @default(PENDING)
  reason     String?
  notes      String?
  createdAt  DateTime          @default(now())
  updatedAt  DateTime          @updatedAt
  queueToken QueueToken?       @relation("AppointmentToken")

  @@index([patientId])
  @@index([doctorId])
  @@index([status])
  @@index([date])
}

model MedicalRecord {
  id          String   @id @default(uuid())
  patientId   String
  patient     Patient  @relation(fields: [patientId], references: [id], onDelete: Cascade)
  recordType  String // e.g., "Consultation", "Surgery", "General"
  description String
  date        DateTime @default(now())
  fileUrl     String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([patientId])
}

model Prescription {
  id        String             @id @default(uuid())
  patientId String
  patient   Patient            @relation(fields: [patientId], references: [id])
  doctorId  String
  doctor    Doctor             @relation(fields: [doctorId], references: [id])
  date      DateTime           @default(now())
  notes     String?
  items     PrescriptionItem[]
  createdAt DateTime           @default(now())
  updatedAt DateTime           @updatedAt
  status    String             @default("PENDING") // PENDING, FULFILLED

  @@index([patientId])
  @@index([doctorId])
}

model PrescriptionItem {
  id             String       @id @default(uuid())
  prescriptionId String
  prescription   Prescription @relation(fields: [prescriptionId], references: [id], onDelete: Cascade)
  medicineId     String
  medicine       Medicine     @relation(fields: [medicineId], references: [id])
  dosage         String
  frequency      String
  duration       String
  instructions   String?

  @@index([prescriptionId])
  @@index([medicineId])
}

model MedicineCategory {
  id          String     @id @default(uuid())
  name        String     @unique
  description String?
  medicines   Medicine[]
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
}

model Medicine {
  id           String           @id @default(uuid())
  name         String
  categoryId   String
  category     MedicineCategory @relation(fields: [categoryId], references: [id])
  manufacturer String
  unitPrice    Float
  stockLevel   Int              @default(0)
  minStock     Int              @default(10)
  expiryDate   DateTime?
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt

  prescriptionItems     PrescriptionItem[]
  inventoryTransactions InventoryTransaction[]
  billItems             BillItem[]

  @@index([categoryId])
}

model InventoryTransaction {
  id              String   @id @default(uuid())
  medicineId      String
  medicine        Medicine @relation(fields: [medicineId], references: [id])
  transactionType String // "IN", "OUT", "ADJUSTMENT"
  quantity        Int
  unitPrice       Float?
  notes           String?
  date            DateTime @default(now())

  @@index([medicineId])
}

model LabTest {
  id          String      @id @default(uuid())
  name        String      @unique
  description String?
  price       Float
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  labReports  LabReport[]
}

model LabReport {
  id        String   @id @default(uuid())
  patientId String
  patient   Patient  @relation(fields: [patientId], references: [id])
  testId    String
  test      LabTest  @relation(fields: [testId], references: [id])
  status    String   @default("PENDING") // PENDING, COMPLETED, CANCELLED
  result    String?
  fileUrl   String?
  date      DateTime @default(now())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([patientId])
  @@index([testId])
  @@index([status])
}

model Bill {
  id          String     @id @default(uuid())
  patientId   String
  patient     Patient    @relation(fields: [patientId], references: [id])
  totalAmount Float
  paidAmount  Float      @default(0)
  status      String     @default("UNPAID") // UNPAID, PARTIAL, PAID
  dueDate     DateTime?
  items       BillItem[]
  payments    Payment[]
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  @@index([patientId])
  @@index([status])
}

model BillItem {
  id          String    @id @default(uuid())
  billId      String
  bill        Bill      @relation(fields: [billId], references: [id], onDelete: Cascade)
  description String
  amount      Float
  quantity    Int       @default(1)
  type        String // CONSULTATION, LAB, MEDICINE, OTHER
  medicineId  String? // Optional relation if it's a medicine
  medicine    Medicine? @relation(fields: [medicineId], references: [id])

  @@index([billId])
  @@index([medicineId])
}

model Payment {
  id            String   @id @default(uuid())
  billId        String
  bill          Bill     @relation(fields: [billId], references: [id], onDelete: Cascade)
  amount        Float
  paymentMethod String // CASH, CARD, ONLINE
  transactionId String?
  date          DateTime @default(now())
  createdAt     DateTime @default(now())

  @@index([billId])
}

model Notification {
  id                String    @id @default(uuid())
  userId            String
  user              User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  title             String
  message           String
  type              String // APPOINTMENT, LAB, PRESCRIPTION, BILLING, SYSTEM, VOICE_NOTE, CERTIFICATE
  isRead            Boolean   @default(false)
  readAt            DateTime?
  relatedEntityType String?
  relatedEntityId   String?
  channelsSent      String[] // Array of channels, e.g., ["IN_APP", "EMAIL"]
  createdAt         DateTime  @default(now())

  @@index([userId])
  @@index([isRead])
}

model AuditLog {
  id        String   @id @default(uuid())
  userId    String?
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  action    String
  entity    String
  entityId  String
  details   Json?
  ipAddress String?
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([entity, entityId])
}

model AIInteraction {
  id             String   @id @default(uuid())
  userId         String
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  conversationId String?
  toolType       String
  input          Json
  output         Json
  provider       String
  timestamp      DateTime @default(now())

  @@index([userId])
  @@index([conversationId])
}

model VoiceNote {
  id             String   @id @default(uuid())
  doctorId       String
  doctor         Doctor   @relation(fields: [doctorId], references: [id], onDelete: Cascade)
  consultationId String?
  url            String
  duration       Int
  createdAt      DateTime @default(now())

  @@index([doctorId])
}

model AISetting {
  id        String   @id @default(uuid())
  key       String   @unique
  value     Json
  updatedAt DateTime @updatedAt
}

model PrescriptionTemplate {
  id        String   @id @default(uuid())
  doctorId  String
  doctor    Doctor   @relation(fields: [doctorId], references: [id], onDelete: Cascade)
  name      String
  items     Json // Array of standardized prescription items
  createdAt DateTime @default(now())

  @@index([doctorId])
}

// ─────────────────────────────────────────────────────────────
// Phase 3: Smart Operations Extension
// ─────────────────────────────────────────────────────────────

enum BedStatus {
  AVAILABLE
  OCCUPIED
  RESERVED
  CLEANING
}

enum BedType {
  ICU
  GENERAL
  PRIVATE
}

enum AmbulanceStatus {
  AVAILABLE
  REQUESTED
  DISPATCHED
  EN_ROUTE
  ARRIVED
  COMPLETED
}

enum BloodRequestStatus {
  PENDING
  APPROVED
  REJECTED
  FULFILLED
}

enum QueueTokenStatus {
  WAITING
  CALLED
  IN_CONSULTATION
  COMPLETED
  SKIPPED
}

// 3.1 Bed Management
model Ward {
  id          String   @id @default(uuid())
  name        String   @unique
  description String?
  beds        Bed[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Bed {
  id               String          @id @default(uuid())
  wardId           String
  ward             Ward            @relation(fields: [wardId], references: [id], onDelete: Cascade)
  bedNumber        String
  type             BedType         @default(GENERAL)
  status           BedStatus       @default(AVAILABLE)
  currentPatientId String?
  currentPatient   Patient?        @relation("CurrentBed", fields: [currentPatientId], references: [id])
  notes            String?
  assignments      BedAssignment[]
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt

  @@unique([wardId, bedNumber])
  @@index([wardId])
  @@index([status])
  @@index([type])
}

model BedAssignment {
  id           String    @id @default(uuid())
  bedId        String
  bed          Bed       @relation(fields: [bedId], references: [id], onDelete: Cascade)
  patientId    String
  patient      Patient   @relation("BedAssignments", fields: [patientId], references: [id])
  admittedAt   DateTime  @default(now())
  dischargedAt DateTime?
  notes        String?
  createdAt    DateTime  @default(now())

  @@index([bedId])
  @@index([patientId])
}

// 3.2 Ambulance Module
model Ambulance {
  id            String             @id @default(uuid())
  vehicleNumber String             @unique
  driverName    String
  driverPhone   String
  model         String?
  status        AmbulanceStatus    @default(AVAILABLE)
  notes         String?
  requests      AmbulanceRequest[]
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt
}

model AmbulanceRequest {
  id            String          @id @default(uuid())
  ambulanceId   String?
  ambulance     Ambulance?      @relation(fields: [ambulanceId], references: [id])
  patientId     String?
  patient       Patient?        @relation("AmbulanceRequests", fields: [patientId], references: [id])
  requestedById String
  pickupAddress String
  destination   String          @default("NovaCare Hospital")
  priority      String          @default("NORMAL")
  status        AmbulanceStatus @default(REQUESTED)
  notes         String?
  requestedAt   DateTime        @default(now())
  dispatchedAt  DateTime?
  arrivedAt     DateTime?
  completedAt   DateTime?
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  @@index([status])
  @@index([patientId])
}

// 3.3 Blood Bank
model BloodInventory {
  id          String     @id @default(uuid())
  bloodGroup  BloodGroup
  units       Int        @default(0)
  collectedAt DateTime   @default(now())
  expiresAt   DateTime
  location    String?
  notes       String?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  @@index([bloodGroup])
  @@index([expiresAt])
}

model Donor {
  id               String     @id @default(uuid())
  name             String
  bloodGroup       BloodGroup
  phone            String
  email            String?
  address          String?
  lastDonationDate DateTime?
  isEligible       Boolean    @default(true)
  notes            String?
  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @updatedAt

  @@index([bloodGroup])
}

model BloodRequest {
  id            String             @id @default(uuid())
  patientId     String?
  patient       Patient?           @relation("BloodRequests", fields: [patientId], references: [id])
  requestedById String
  department    String?
  bloodGroup    BloodGroup
  units         Int
  urgency       String             @default("ROUTINE")
  status        BloodRequestStatus @default(PENDING)
  notes         String?
  approvedAt    DateTime?
  fulfilledAt   DateTime?
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt

  @@index([bloodGroup])
  @@index([status])
  @@index([patientId])
}

// 3.5 Live Queue System
model QueueToken {
  id                  String           @id @default(uuid())
  tokenNumber         Int
  doctorId            String
  doctor              Doctor           @relation(fields: [doctorId], references: [id], onDelete: Cascade)
  appointmentId       String?          @unique
  appointment         Appointment?     @relation("AppointmentToken", fields: [appointmentId], references: [id])
  patientId           String
  patient             Patient          @relation("QueueTokens", fields: [patientId], references: [id])
  status              QueueTokenStatus @default(WAITING)
  calledAt            DateTime?
  consultationEndedAt DateTime?
  date                DateTime         @default(now())
  createdAt           DateTime         @default(now())
  updatedAt           DateTime         @updatedAt

  @@index([doctorId])
  @@index([patientId])
  @@index([status])
  @@index([date])
}

// 3.6 Organ Donation Registry
model OrganDonor {
  id             String       @id @default(uuid())
  patientId      String?
  patient        Patient?     @relation("OrganDonors", fields: [patientId], references: [id])
  firstName      String
  lastName       String
  bloodGroup     BloodGroup
  organ          String
  contactNumber  String
  status         String       @default("PENDING") // PENDING, APPROVED, REJECTED, MATCHED
  registeredById String
  registeredBy   User         @relation("RegisteredOrganDonors", fields: [registeredById], references: [id])
  matches        OrganMatch[]
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@index([bloodGroup])
  @@index([status])
}

model OrganRecipient {
  id             String       @id @default(uuid())
  patientId      String?
  patient        Patient?     @relation("OrganRecipients", fields: [patientId], references: [id])
  firstName      String
  lastName       String
  bloodGroup     BloodGroup
  organ          String
  urgency        String       @default("NORMAL") // NORMAL, CRITICAL
  contactNumber  String
  status         String       @default("PENDING") // PENDING, UNDER_REVIEW, APPROVED, MATCHED, COMPLETED
  registeredById String
  registeredBy   User         @relation("RegisteredOrganRecipients", fields: [registeredById], references: [id])
  matches        OrganMatch[]
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@index([bloodGroup])
  @@index([status])
}

model OrganMatch {
  id          String         @id @default(uuid())
  donorId     String
  donor       OrganDonor     @relation(fields: [donorId], references: [id])
  recipientId String
  recipient   OrganRecipient @relation(fields: [recipientId], references: [id])
  status      String         @default("PENDING") // PENDING, APPROVED, REJECTED, COMPLETED
  approverId  String?
  approver    User?          @relation(name: "MatchApprover", fields: [approverId], references: [id])
  notes       String?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  @@index([status])
}

// System Configuration
model SystemSetting {
  id        String   @id @default(uuid())
  key       String   @unique
  value     String
  updatedAt DateTime @updatedAt
}
